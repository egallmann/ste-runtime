# Dependencies
node_modules/

# Build output (compiled TypeScript)
dist/

# Runtime state (regenerated by RECON)
# .ste/state/ - Only track README.md (ignore all other files)
.ste/state/*
!.ste/state/README.md
# .ste-self/ - Track everything (example for reviewers)
!.ste-self/

# Runtime cache (downloaded specs, auto-regenerated)
.ste/cache/
.ste-self/cache/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/
.nyc_output/

# Temporary test/coverage output files
coverage-full.txt
coverage-temp.txt
test-output.txt

# Temporary files
*.tmp
.tmp/

# Internal development issues (pre-release)
# Remove this line once project is public and issues should be tracked
documentation/issues/

