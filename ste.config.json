{
  "projectRoot": "..",
  "languages": [
    "python"
  ],
  "sourceDirs": [
    "src"
  ],
  "ignorePatterns": [
    "**/__pycache__/**",
    "**/*.egg-info/**",
    "**/htmlcov/**",
    "**/tests/**",
    "**/.venv/**",
    "**/venv/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/ste-runtime-private/**"
  ],
  "stateDir": ".ste/state",
  "watchdog": {
    "enabled": false,
    "debounceMs": 500,
    "aiEditDebounceMs": 2000,
    "syntaxValidation": true,
    "transactionDetection": true,
    "stabilityCheckMs": 100,
    "patterns": ["**/*.py"],
    "ignore": [".git", "node_modules", ".venv", "__pycache__", "dist", "build", "ste-runtime-private"],
    "fullReconciliationInterval": 300000,
    "fallbackPolling": false,
    "pollingInterval": 5000
  },
  "mcp": {
    "transport": "stdio",
    "logLevel": "info"
  },
  "rss": {
    "defaultDepth": 2,
    "maxResults": 50
  }
}
