{
  "name": "ste-runtime",
  "version": "0.9.0-experimental",
  "description": "STE Runtime [EXPERIMENTAL] - Component implementation of RECON and RSS for AI-assisted development. NOT production-ready.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "ste": "dist/cli/index.js",
    "recon": "dist/cli/recon-cli.js",
    "rss": "dist/cli/rss-cli.js"
  },
  "scripts": {
    "init": "node scripts/init.cjs",
    "init:mcp": "node scripts/init.cjs --mcp",
    "init:check": "node scripts/init.cjs --check",
    "bootstrap": "node scripts/init.cjs",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:integration": "node -e \"console.log('No integration tests are currently defined for ste-runtime.')\"",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src vitest.config.ts",
    "lint:fix": "eslint src vitest.config.ts --fix",
    "recon": "node dist/cli/recon-cli.js",
    "recon:full": "node dist/cli/recon-cli.js --mode=full",
    "recon:self": "node dist/cli/recon-cli.js --self",
    "recon:init": "node dist/cli/recon-cli.js --init",
    "rss": "node dist/cli/rss-cli.js",
    "rss:stats": "node dist/cli/rss-cli.js stats",
    "rss:search": "node dist/cli/rss-cli.js search",
    "rss:context": "node dist/cli/rss-cli.js context",
    "diagram:render": "mmdc -i documentation/diagrams/ste-runtime-architecture.mmd -o documentation/diagrams/ste-runtime-architecture.svg",
    "diagram:png": "mmdc -i documentation/diagrams/ste-runtime-architecture.mmd -o documentation/diagrams/ste-runtime-architecture.png",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chokidar": "^3.5.3",
    "commander": "^14.0.2",
    "execa": "^8.0.1",
    "globby": "^13.0.0",
    "js-yaml": "^4.1.0",
    "lru-cache": "^10.0.0",
    "typescript": "^5.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.4.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "husky": "9.1.7",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.9.4",
  "keywords": [
    "ste",
    "recon",
    "rss",
    "ai-doc",
    "semantic-extraction",
    "context-assembly",
    "ai-agent"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egallmann/ste-runtime.git"
  },
  "bugs": {
    "url": "https://github.com/egallmann/ste-runtime/issues"
  },
  "homepage": "https://github.com/egallmann/ste-runtime#readme"
}
