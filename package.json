{
  "name": "ste-runtime",
  "version": "0.9.0-experimental",
  "description": "STE Runtime [EXPERIMENTAL] - Component implementation of RECON and RSS for AI-assisted development. NOT production-ready.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ste": "dist/cli/index.js",
    "recon": "dist/cli/recon-cli.js",
    "rss": "dist/cli/rss-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --testPathPattern='\\.(test|spec)\\.ts$' --exclude='**/integration/**'",
    "test:integration": "vitest run --testPathPattern='integration'",
    "test:coverage": "vitest run --coverage",
    "recon": "node dist/cli/recon-cli.js",
    "recon:full": "node dist/cli/recon-cli.js --mode=full",
    "recon:self": "node dist/cli/recon-cli.js --self",
    "recon:init": "node dist/cli/recon-cli.js --init",
    "rss": "node dist/cli/rss-cli.js",
    "rss:stats": "node dist/cli/rss-cli.js stats",
    "rss:search": "node dist/cli/rss-cli.js search",
    "rss:context": "node dist/cli/rss-cli.js context",
    "diagram:render": "mmdc -i documentation/diagrams/ste-runtime-architecture.mmd -o documentation/diagrams/ste-runtime-architecture.svg",
    "diagram:png": "mmdc -i documentation/diagrams/ste-runtime-architecture.mmd -o documentation/diagrams/ste-runtime-architecture.png",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "chokidar": "^3.5.3",
    "commander": "^14.0.2",
    "execa": "^8.0.1",
    "globby": "^13.0.0",
    "js-yaml": "^4.1.0",
    "lru-cache": "^10.0.0",
    "typescript": "^5.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.2.0",
    "husky": "9.1.7",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ste",
    "recon",
    "rss",
    "ai-doc",
    "semantic-extraction",
    "context-assembly",
    "ai-agent"
  ],
  "license": "Apache-2.0"
}
